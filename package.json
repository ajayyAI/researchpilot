{
  "name": "researchpilot",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/ajayyAI/researchpilot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajayyAI/researchpilot.git"
  },
  "bugs": {
    "url": "https://github.com/ajayyAI/researchpilot/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check": "bunx --bun biome check --write .",
    "check:unsafe": "bunx --bun biome check --write --unsafe .",
    "lint": "bunx --bun biome lint .",
    "lint:fix": "bunx --bun biome lint --write .",
    "format": "bunx --bun biome format --write .",
    "ci": "bunx --bun biome check .",
    "type-check": "tsc --noEmit",
    "validate": "bun run type-check && bun run ci && bun run build",
    "clean": "rm -rf .next",
    "clean:full": "rm -rf .next node_modules"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.10",
    "@ai-sdk/openai": "^3.0.12",
    "@mendable/firecrawl-js": "^4.11.1",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.39",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.562.0",
    "next": "16.1.3",
    "p-limit": "^7.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
