# ── Required ──────────────────────────────────────────

FIRECRAWL_API_KEY=           # https://firecrawl.dev

# Pick ONE provider and set its key:
AI_PROVIDER=openrouter       # openai | openrouter | groq
OPENROUTER_API_KEY=          # https://openrouter.ai/keys
# OPENAI_API_KEY=            # https://platform.openai.com/api-keys
# GROQ_API_KEY=              # https://console.groq.com

# ── Model Tiers (optional) ───────────────────────────
# Each tier defaults to a sensible model per provider.
# Override any tier to customize cost vs quality.
#
# AI_MODEL=                          # override all tiers at once
# AI_MODEL_FAST=                     # extraction, source scoring (default: mistralai/mistral-small-3.1-24b-instruct:free)
# AI_MODEL_STRATEGIC=                # planning, reasoning (default: meta-llama/llama-3.3-70b-instruct:free)

# ── Search (optional) ────────────────────────────────
# TAVILY_API_KEY=                    # https://tavily.com — adds a second search source
# FIRECRAWL_CONCURRENCY=2           # increase with paid Firecrawl plan

# ── Site ──────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://researchpilot.dev
