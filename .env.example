# ==============================================
# Deep Research Engine - Environment Configuration
# ==============================================

# OpenAI API Key (required)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Firecrawl API Key (required)
# Get your key at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ==============================================
# Optional Configuration
# ==============================================

# AI Model to use (default: gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# AI_MODEL=gpt-4o

# Firecrawl concurrency limit (default: 2)
# Increase if you have a paid Firecrawl plan
# FIRECRAWL_CONCURRENCY=2

# Model context size in tokens (default: 128000)
# CONTEXT_SIZE=128000
