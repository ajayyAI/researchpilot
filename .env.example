# ==============================================
# Deep Research Engine - Environment Configuration
# ==============================================

# OpenAI API Key (required if using OpenAI)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Firecrawl API Key (required)
# Get your key at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ==============================================
# Optional Configuration
# ==============================================

# AI Provider (default: openai)
# Options: openai, groq, openrouter
# RECOMMENDED: openrouter - 30+ free models with generous limits!
# AI_PROVIDER=openai

# OpenRouter API Key (RECOMMENDED - best free option!)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key

# Groq API Key (free tier, but strict rate limits)
# Get your key at: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key

# AI Model to use (provider-specific, uses smart defaults if not set)
# OpenAI: gpt-4o, gpt-4o-mini
# OpenRouter: google/gemini-2.0-flash-exp:free, meta-llama/llama-4-scout:free
# Groq: meta-llama/llama-4-scout-17b-16e-instruct
# AI_MODEL=gpt-4o

# Firecrawl concurrency limit (default: 2)
# Increase if you have a paid Firecrawl plan
# FIRECRAWL_CONCURRENCY=2

# Model context size in tokens (default: 128000)
# CONTEXT_SIZE=128000

# ==============================================
# Public Configuration
# ==============================================

# Your site URL (used for Open Graph meta tags)
# NEXT_PUBLIC_SITE_URL=https://researchpilot.dev
